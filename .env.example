# CloudArmor sanitized environment example
# Copy this file to .env and replace placeholder values with your real local/deployment values.
# Do NOT commit the real .env file to GitHub.

# ------------------------------------------------------------
# Domain / Server
# ------------------------------------------------------------
DOMAIN_NAME=cloudarmor.example.com
SERVER_PUBLIC_IP=203.0.113.10
SSH_PORT=2222
ADMIN_USER=cloudarmor_admin

# ------------------------------------------------------------
# Nextcloud
# ------------------------------------------------------------
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=replace_with_secure_nextcloud_admin_password
NEXTCLOUD_TRUSTED_DOMAINS=cloudarmor.example.com

# ------------------------------------------------------------
# MariaDB
# ------------------------------------------------------------
MYSQL_ROOT_PASSWORD=replace_with_secure_mysql_root_password
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud_user
MYSQL_PASSWORD=replace_with_secure_mysql_user_password

# ------------------------------------------------------------
# SSL / Let's Encrypt
# ------------------------------------------------------------
LETSENCRYPT_EMAIL=admin@example.com

# ------------------------------------------------------------
# Backup Configuration
# ------------------------------------------------------------
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7

# ------------------------------------------------------------
# Optional Monitoring
# ------------------------------------------------------------
HEALTHCHECK_URL=https://cloudarmor.example.com
